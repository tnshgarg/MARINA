{
  "name": "marina",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",

    "db:generate": "drizzle-kit generate",

    "db:migrate":      "tsx --env-file=.env scripts/db-migrate.ts",
    "db:migrate:dev":  "tsx --env-file=.env scripts/db-migrate.ts",
    "db:migrate:prod": "tsx --env-file=.env.production scripts/db-migrate.ts",

    "db:apply":        "tsx --env-file=.env scripts/db-apply-pending.ts",
    "db:apply:dev":    "tsx --env-file=.env scripts/db-apply-pending.ts",
    "db:apply:prod":   "tsx --env-file=.env.production scripts/db-apply-pending.ts",
    "db:apply:ci":     "tsx scripts/db-apply-pending.ts",

    "db:push":      "set -a && . ./.env && set +a && drizzle-kit push",
    "db:push:dev":  "set -a && . ./.env && set +a && drizzle-kit push",
    "db:push:prod": "echo '⚠️  drizzle-kit push against PRODUCTION can DROP columns. Hit Enter to continue, Ctrl-C to abort.' && read _ && set -a && . ./.env.production && set +a && drizzle-kit push",

    "db:studio":      "set -a && . ./.env && set +a && drizzle-kit studio",
    "db:studio:dev":  "set -a && . ./.env && set +a && drizzle-kit studio",
    "db:studio:prod": "set -a && . ./.env.production && set +a && drizzle-kit studio",

    "seed:demo":       "tsx --env-file=.env scripts/seed-demo.ts",
    "seed:demo:dev":   "tsx --env-file=.env scripts/seed-demo.ts",
    "seed:demo:prod":  "tsx --env-file=.env.production scripts/seed-demo.ts",

    "seed:codes":      "tsx --env-file=.env scripts/seed-early-bird-codes.ts",
    "seed:codes:dev":  "tsx --env-file=.env scripts/seed-early-bird-codes.ts",
    "seed:codes:prod": "tsx --env-file=.env.production scripts/seed-early-bird-codes.ts"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@neondatabase/serverless": "^1.1.0",
    "@octokit/rest": "^22.0.1",
    "@types/nodemailer": "^8.0.1",
    "@vercel/blob": "^2.4.0",
    "drizzle-orm": "^0.45.2",
    "groq-sdk": "^1.2.1",
    "next": "16.2.7",
    "next-auth": "5.0.0-beta.31",
    "nodemailer": "^7.0.13",
    "openai": "^6.42.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.41",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
