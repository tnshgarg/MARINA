{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/sweep",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/calendar",
      "schedule": "*/30 3-13 * * 1-5"
    },
    {
      "path": "/api/cron/states",
      "schedule": "30 18 * * *"
    },
    {
      "path": "/api/cron/stories",
      "schedule": "0 19 * * *"
    }
  ]
}
