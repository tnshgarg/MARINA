{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm db:apply:ci && next build",
  "crons": [
    {
      "path": "/api/cron/sweep",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/calendar",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/github",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/states",
      "schedule": "30 18 * * *"
    },
    {
      "path": "/api/cron/stories",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/cron/digest",
      "schedule": "30 2 * * *"
    },
    {
      "path": "/api/cron/digest/daily",
      "schedule": "30 14 * * *"
    },
    {
      "path": "/api/cron/slack-brief",
      "schedule": "30 2 * * 1-5"
    },
    {
      "path": "/api/cron/celebrations",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/standup-reminder",
      "schedule": "0 4 * * 1-5"
    }
  ]
}
